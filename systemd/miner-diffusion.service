[Unit]
Description=MINER — Moniteur diffusion email (agent 5 : Brevo)
After=network-online.target ollama.service
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/Projets_en_Production/MINER
EnvironmentFile=/home/ubuntu/Projets_en_Production/MINER/.env
ExecStart=/home/ubuntu/Projets_en_Production/MINER/.venv/bin/python monitor_diffusion.py
Restart=on-failure
RestartSec=30
StandardOutput=append:/var/log/miner/monitor_diffusion.log
StandardError=append:/var/log/miner/monitor_diffusion.log

[Install]
WantedBy=multi-user.target
